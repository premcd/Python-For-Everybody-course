#programme qui retourne le nombre de mails recus pour chaque heure, dans l ordre chronologique


filename = input('enter a file name:')
if len(filename) < 1: filename = 'mbox-short.txt'
fhandle = open(filename)
#on peut se passer de hour_list si on construit le dict dans la loop for a mesure qu'on rencontre des heures
#mais du coup on ne peut pas afficher la liste des heures, a voir
hour_list = list()
hour_count = dict()
#go through the different lines
for line in fhandle:
#    line.rstrip()
#    print(line)
#create a list of words for each line
    words = line.split()
#only keep lines that begin with From
    if len(words)<5 or words[0] !='From':
        continue
    print(line.rstrip())
#find the date by searching for':' and get the previous 2 characters of the line string
    pos=line.find(':')
#create the var hour that will contain the string
    hour=line[pos-2:pos]
    print(hour)
#populate the hour_list with all hour values retrieved by parsing lines
    hour_list.append(hour)
#add counting idiom for dictionaries
print("hour_list:\n",hour_list)
#we can sort the list of hours directly here before creating the dictionnary of counts, then the dictionnary will
#sorted already. Otherwise utiliser les tuples-items pour faire un sort des keys
hour_list.sort()
print("hour_list.sort:\n", hour_list)
for hr in hour_list:
     hour_count[hr] = hour_count.get(hr,0) + 1
print(hour_count)
    
#maintenant on peut ordonner le dict de la plus grande a la plus petite valeur d'heure
tup=hour_count.items()
print(tup)
print(sorted(tup))
for k,v in sorted(tup):
    print (k,v)


