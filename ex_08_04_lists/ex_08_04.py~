file_name = input ('what is the name of the file?')
fhandle = open(file_name)
word_list =list()
for line in fhandle:
    print(line.rstrip())
    words = line.split()
    
    for word in words:
        if word in word_list:
            continue
        word_list.append(word)
        word_list.sort()
print(word_list)
